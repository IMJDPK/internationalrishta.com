# Supabase (Get from: https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Daily.co Video (Already configured)
NEXT_PUBLIC_DAILY_API_KEY=0e11919686e89e5720f0b76083c804634ebe069749b2dc58128482f3500b1d7b
NEXT_PUBLIC_DAILY_DOMAIN=internationalrishta.daily.co

# FingerprintJS (Optional - for device tracking)
NEXT_PUBLIC_FINGERPRINTJS_PUBLIC_KEY=your-fingerprint-public-key

# Site URL
# Local development: http://localhost:3000
# Production: https://hosterpk.com
NEXT_PUBLIC_APP_URL=https://hosterpk.com

# Payment Gateway (RAAST/JazzCash - set up later)
NEXT_PUBLIC_RAAST_MERCHANT_ID=your_merchant_id
NEXT_PUBLIC_RAAST_API_KEY=your_api_key
RAAST_WEBHOOK_SECRET=your_webhook_secret

# Email Service (Resend.com - set up later)
RESEND_API_KEY=your_resend_api_key

# Node Environment
NODE_ENV=production
